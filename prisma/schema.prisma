generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum PaymentType {
  CREDIT
  DEBIT
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

model User {
  id       String  @id @default(uuid())
  email    String  @unique
  credit   Int     @default(3)
  name     String?
  password String

  role Role @default(USER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mensagens Mensagem[]

  payments payment[]
}

enum AuthorType {
  USER
  ASSISTANT
}

model Mensagem {
  id        String     @id @default(uuid())
  content   String
  author    AuthorType
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  user   User   @relation(fields: [userId], references: [id])
  userId String
}

model payment {
  id     String        @id @default(uuid())
  externalId String @unique
  amount Int
  type   PaymentType
  status PaymentStatus
  credit_amount Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id])
  userId String
}
